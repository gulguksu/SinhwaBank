datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  name         String
  isAdmin      Boolean       @default(false)
  job          String?       // 직업: 국세청장, 은행원, 경찰서장, 낙농업자, 에너지지킴이, 청소업자, 날쌘돌이
  transactions Transaction[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  type        String   // "deposit" or "withdraw"
  amount      Int
  description String
  createdAt   DateTime @default(now())
}

model GlobalState {
  id        Int @id @default(1)
  globalTax Int @default(0)
}

model TaxHistory {
  id           Int      @id @default(autoincrement())
  amountBefore Int
  amountAfter  Int
  diff         Int
  description  String
  createdAt    DateTime @default(now())
}


